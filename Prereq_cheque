
#create prerequisite map and apply it to courses listed in course_objects


def check_eligibility(courselist) -> str:
    course_map = {
    course.code: course for course in (courselist)
    }

    course_code = input("Enter the course code you want to enroll in: ").strip().upper()
    course = course_map.get(course_code)

    if not course:
        return f"Course '{course_code}' not found."

    if not course.prerequisites:
        return f"You are eligible for {course.code} — no prerequisites required."

    unmet = []
    for prereq_code in course.prerequisites:
        prereq = course_map.get(prereq_code)
        if prereq:
            answer = input(f"Have you passed {prereq_code} - {prereq.name}? (y/n): ").strip().lower()
            if answer != "y":
                unmet.append(prereq_code)

    if unmet:
        return f"Not eligible for {course.code}: you have not passed {', '.join(unmet)}."
    return f"You are eligible for {course.code}!"
